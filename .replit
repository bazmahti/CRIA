modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8001
externalPort = 3001

[[ports]]
localPort = 8002
externalPort = 3003

[[ports]]
localPort = 8003
externalPort = 3002

[[ports]]
localPort = 8004
externalPort = 4200

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 19806
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "xcodebuild", "zlib"]

[userenv]

[userenv.shared]
CORS_ALLOWED_ORIGINS = "https://convergent-research-hub.replit.app,https://d54542fa-70d1-4299-aef4-6f64dc49ea62-00-2otvmxu2q6fvv.spock.replit.dev"
CRIA_MODEL_NAME = "gpt-5.1"
